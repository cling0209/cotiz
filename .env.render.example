# Render (free OK) + Neon + Resend — correo @romulo.cl sin SMTP
# Copiar al panel Environment de Render (sin comillas).

APP_NAME=Tienda Rómulo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cotiza.romulo.cl
APP_TIMEZONE=America/Santiago

DB_CONNECTION=pgsql
DB_HOST=ep-xxx.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=
# Host pooler Neon (…-pooler.…neon.tech): usar DB_EMULATE_PREPARES=true o conexión directa sin -pooler
# DB_EMULATE_PREPARES=true
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
# No usar REDIS_* en Render free si no hay servicio Redis (dejar sin definir o CACHE_STORE=database)
DB_QUEUE_RETRY_AFTER=43200
MAEPROD_IMPORT_BACKGROUND=true
# En Render free: worker en el MISMO Web Service (comparte storage/app/imports con la subida)
RUN_QUEUE_WORKER=true

# Mercado Público — resultados Compra Ágil (admin cotiza.romulo.cl)
# Alinear masivo con «Consultar MP» individual: mismos timeout, reintentos y low-speed.
MERCADOPUBLICO_TICKET=
MERCADOPUBLICO_API_TIMEOUT_SEG=120
MERCADOPUBLICO_API_CONNECT_TIMEOUT_SEG=30
# 0 = desactiva corte por velocidad baja (recomendado si MP responde lento pero termina).
MERCADOPUBLICO_API_LOW_SPEED_TIME_SEG=0
MERCADOPUBLICO_API_LOW_SPEED_LIMIT_BYTES=0
MERCADOPUBLICO_API_REINTENTOS=2
MERCADOPUBLICO_API_ESPERA_REINTENTO_SEG=3
# Lote / pipeline: máx. en vuelo + espera entre disparos (no espera a que termine la anterior).
MERCADOPUBLICO_RESULTADOS_CONCURRENCIA=1
# Tope superior (CONCURRENCIA no puede superar este valor; subir si necesita más en paralelo).
MERCADOPUBLICO_RESULTADOS_CONCURRENCIA_MAX=50
MERCADOPUBLICO_RESULTADOS_STAGGER_MS=2000
# Watchdog masivo: >= TIMEOUT + margen. Solo si worker murió.
MERCADOPUBLICO_RESULTADOS_NOTA_MAX_SEG=180
MERCADOPUBLICO_RESULTADOS_NOTA_ALERTA_SEG=120
MERCADOPUBLICO_RESULTADOS_DELAY_MS=500

# Resend (dominio romulo.cl verificado en resend.com)
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=tienda@romulo.cl
MAIL_FROM_NAME=Tienda Rómulo

ADMIN_OTP_ENABLED=true

LOG_CHANNEL=stderr
LOG_LEVEL=error

TRANSBANK_COMMERCE_CODE=
TRANSBANK_API_KEY=
TRANSBANK_ENV=integration
TRANSBANK_RETURN_URL=https://tienda.romulo.cl/checkout/webpay/return

RUN_MIGRATIONS=true
RUN_SEED=false
L5_SWAGGER_GENERATE_ALWAYS=false

# Cotiz — negocio (config/cotiz.php; equivalente legacy config.php)
COTIZ_CODIGO_BODEGA=01
COTIZ_CONCEPTO_BODEGA=26
COTIZ_CODIGO_PROVEEDOR=76185139
COTIZ_PROD_VALOR_FECHA_MESES=3
COTIZ_FACTOR_PRECIO_VENTA=1.22
# Romulo → Reicol; en Reicol usar https://cotiza.romulo.cl/api/v1/usuario y COTIZ_SISTEMA=Reicol
COTIZ_API_USUARIO_URL=https://cotiza.reicol.cl/api/v1/usuario
COTIZ_SISTEMA=Romulo
COTIZ_API_NOTA_USER=
COTIZ_API_NOTA_PASSWORD=
# Consulta duplicados Romulo ↔ Reicol (opcional si APP_URL es cotiza.reicol.cl o cotiza.romulo.cl)
COTIZ_API_CONSULTA_NRO_COTIZACION=

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=romulo-imagenes
R2_ENDPOINT=https://0d252868f15b7d133851046e6302d540.r2.cloudflarestorage.com
R2_PUBLIC_URL=
R2_IMAGE_PREFIX=productos
R2_REGION=auto
PRODUCT_STORAGE_DISK=r2
PRODUCT_IMAGE_BASE_URL=
PRODUCT_IMAGE_FALLBACK_URL=https://picsum.photos/seed/placeholder/800/800

# --- Alternativa Render DE PAGO + SMTP Romulo (no usar con free) ---
# MAIL_MAILER=smtp
# MAIL_HOST=mail.romulo.cl
# MAIL_PORT=465
# MAIL_SCHEME=smtps
# MAIL_USERNAME=tienda@romulo.cl
# MAIL_PASSWORD=
