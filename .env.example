APP_NAME=Cotiz
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8082
APP_TIMEZONE=America/Santiago

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cotiz
DB_USERNAME=cotiz
DB_PASSWORD=secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@cotiz.local
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_OTP_ENABLED=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8082,127.0.0.1
SESSION_DOMAIN=localhost

L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=http://localhost:8082

# Reicol / Romulo (config/cotiz.php)
COTIZ_EMPRESA_NOMBRE="Comercializadora Reicol SPA"
COTIZ_FACTOR_PRECIO_VENTA=1.22
COTIZ_PROD_VALOR_FECHA_MESES=1

PRODUCT_IMAGE_BASE_URL=https://www.romulo.cl/allproducts/imagenes/productos
PRODUCT_IMAGE_FILENAME_PATTERN={codigo}_medium.jpg
PRODUCT_IMAGE_FALLBACK_URL=https://picsum.photos/seed/placeholder/800/800
