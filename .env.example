APP_NAME=Cotiz
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8082
APP_TIMEZONE=America/Santiago

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cotiz
DB_USERNAME=cotiz
DB_PASSWORD=secret
# Neon pooler (-pooler en host): DB_EMULATE_PREPARES=true (auto si el host contiene "pooler")

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=database
QUEUE_CONNECTION=redis
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@cotiz.local
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_OTP_ENABLED=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8082
# Vacío en local: usar siempre http://localhost:8082 (no 127.0.0.1) para que la cookie de sesión funcione
SESSION_DOMAIN=

L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=http://localhost:8082

# Reicol / Romulo (config/cotiz.php)
COTIZ_EMPRESA_NOMBRE="Comercializadora Reicol SPA"
COTIZ_EMPRESA_RUT="76.356.855-5"
COTIZ_EMPRESA_CORREO=jlocier@reicol.cl
COTIZ_EMPRESA_FONO="+56 9 9044 5886"
COTIZ_EMPRESA_DIRECCION="Santa Carolina Parcela 14-A Lampa, Santiago"
COTIZ_EMPRESA_CUENTA="Banco Estado Cta.Cte. 3854418"
COTIZ_CODIGO_BODEGA=01
COTIZ_CONCEPTO_BODEGA=26
COTIZ_CODIGO_PROVEEDOR=76185139
COTIZ_FACTOR_PRECIO_VENTA=1.22
COTIZ_PROD_VALOR_FECHA_MESES=1
COTIZ_BUSCAR_PRODUCTOS_LIMITE=15
COTIZ_BUSCAR_PRODUCTOS_MIN_CHARS=2
COTIZ_BUSCAR_PRODUCTOS_DEBOUNCE_MS=250
COTIZ_BUSCAR_PRODUCTOS_CANDIDATOS_MAX=250

# Envío cotización a API legacy (notaventalis → apinotaenvio)
COTIZ_API_NOTA_ENVIO_URL=
COTIZ_API_NOTA_ENVIO_USER=
COTIZ_API_NOTA_ENVIO_PASSWORD=

# Cloudflare R2 — imágenes de productos (lectura + subida)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=romulo-imagenes
R2_ENDPOINT=https://0d252868f15b7d133851046e6302d540.r2.cloudflarestorage.com
R2_PUBLIC_URL=
R2_IMAGE_PREFIX=productos
R2_REGION=auto
PRODUCT_STORAGE_DISK=r2

# Lectura: dejar vacío para usar R2_PUBLIC_URL/productos; o override manual:
PRODUCT_IMAGE_BASE_URL=
PRODUCT_IMAGE_FALLBACK_URL=https://picsum.photos/seed/placeholder/800/800

# Origen imágenes legacy (products:migrate-images-r2)
LEGACY_PRODUCT_IMAGES_PATH=
