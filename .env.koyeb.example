# Variables para Koyeb + Neon PostgreSQL (sin Redis/Upstash)

APP_NAME=Tienda Rómulo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://TU-APP.koyeb.app
APP_TIMEZONE=America/Santiago

DB_CONNECTION=pgsql
DB_HOST=ep-xxx.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=
# Alternativa Neon:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Cache, sesiones y colas en PostgreSQL (tablas sessions, cache, jobs)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=43200
MAEPROD_IMPORT_BACKGROUND=true

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@tutienda.cl
MAIL_FROM_NAME=Tienda Rómulo

ADMIN_OTP_ENABLED=true

TRANSBANK_COMMERCE_CODE=
TRANSBANK_API_KEY=
TRANSBANK_ENV=integration
TRANSBANK_RETURN_URL=https://TU-APP.koyeb.app/checkout/webpay/return

RUN_MIGRATIONS=true
RUN_SEED=false
L5_SWAGGER_GENERATE_ALWAYS=false

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=romulo-imagenes
R2_ENDPOINT=https://0d252868f15b7d133851046e6302d540.r2.cloudflarestorage.com
R2_PUBLIC_URL=
R2_IMAGE_PREFIX=productos
R2_REGION=auto
PRODUCT_STORAGE_DISK=r2
PRODUCT_IMAGE_BASE_URL=
